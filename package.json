{
  "name": "@mytake2/feature-flag-client",
  "version": "0.0.0",
  "description": "A feature flag client wrapper for LaunchDarkly.",
  "author": "wesley.thorsen@gmail.com",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "github",
    "url": "https://github.com/mytake2/feature-flag-client"
  },
  "keywords": [
    "feature",
    "flag",
    "client",
    "launchdarkly"
  ],
  "files": [
    "dist-*/**"
  ],
  "exports": {
    ".": {
      "import": "./dist-es/index.js",
      "require": "./dist-cjs/index.js",
      "types": "./dist-types/index.d.ts"
    },
    "./core": {
      "import": "./dist-es/core/index.js",
      "require": "./dist-cjs/core/index.js",
      "types": "./dist-types/core/index.d.ts"
    },
    "./launchdarkly": {
      "import": "./dist-es/launchdarkly/index.js",
      "require": "./dist-cjs/launchdarkly/index.js",
      "types": "./dist-types/launchdarkly/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run clean && npm ci && concurrently 'npm:build:cjs' 'npm:build:es' 'npm:build:types'",
    "build:cjs": "tsc -p tsconfig.cjs.json && tsc-alias",
    "build:es": "tsc -p tsconfig.es.json && tsc-alias",
    "build:types": "tsc -p tsconfig.types.json && tsc-alias",
    "clean": "rimraf ./dist-* && rimraf *.tsbuildinfo",
    "lint": "eslint --fix */**/*.ts && prettier --write */**/*.ts",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tsconfig/recommended": "1.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.19",
    "concurrently": "7.0.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "dependencies": {
    "@launchdarkly/js-server-sdk-common": "^2.15.2",
    "@launchdarkly/node-server-sdk": "^9.9.2"
  }
}
